# Public Experience Cloud page that renders grantApplicationForm
PORTAL_URL=https://<your-domain>.my.site.com/agencyxgrants/

# Salesforce CLI alias or username of the target org
SF_TARGET_ORG=<username-or-alias>

# Experience site id (SELECT Id FROM Site) used for authenticated access
SF_SITE_ID=<Experience-site-id>

# Community URL path prefix used to establish an authenticated session
SF_COMMUNITY_PATH=<community-url-path>
