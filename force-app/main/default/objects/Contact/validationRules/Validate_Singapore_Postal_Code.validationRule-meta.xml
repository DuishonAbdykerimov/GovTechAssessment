<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Validate_Singapore_Postal_Code</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK(TEXT(Application_Status__c))),
    NOT(ISBLANK(MailingPostalCode)),
    NOT(REGEX(MailingPostalCode, &quot;^[0-9]{6}$&quot;))
)</errorConditionFormula>
    <errorDisplayField>MailingPostalCode</errorDisplayField>
    <errorMessage>Enter a valid 6-digit Singapore postal code.</errorMessage>
</ValidationRule>
